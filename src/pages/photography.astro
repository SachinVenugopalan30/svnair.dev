---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

// Try to read images from public/photography folder
let photoList = [];
try {
  const photosDir = path.join(process.cwd(), 'public', 'photography');
  if (fs.existsSync(photosDir)) {
    const files = fs.readdirSync(photosDir);
    photoList = files
      .filter(file => /\.(jpg|jpeg|png|webp|gif)$/i.test(file))
      .map((file, i) => ({
        src: `/photography/${file}`,
        alt: `Photo ${i + 1}`
      }));
  }
} catch (error) {
  console.log('No photography folder found yet');
}

// Fallback placeholder images if no photos exist yet
if (photoList.length === 0) {
  photoList = [
    { src: 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=900&h=600&fit=crop', alt: 'Mountain landscape' },
    { src: 'https://images.unsplash.com/photo-1472214103451-9374bd1c798e?w=900&h=600&fit=crop', alt: 'Forest path' },
    { src: 'https://images.unsplash.com/photo-1501594907352-04cda38ebc29?w=900&h=600&fit=crop', alt: 'Sunset over ocean' },
  ];
}
---

<Layout title="Photography - Sachin">
  <div class="container">
    <section style="padding: 4rem 0;">
      <h1 style="font-size: 3rem; text-align: center; margin-bottom: 1rem;">Photography</h1>
      <p style="text-align: center; font-size: 1.25rem; color: #ffc300; margin-bottom: 3rem; max-width: 700px; margin-left: auto; margin-right: auto;">
        Capturing moments and telling stories through the lens. Here's a collection of my favorite shots from various adventures.
      </p>

      {photoList.length === 0 ? (
        <div class="card" style="text-align: center; padding: 4rem 2rem;">
          <h2 style="margin-bottom: 1rem;">Gallery Coming Soon</h2>
          <p style="color: #ffc300;">Please add images to the <code>public/photography</code> folder to display your photos here.</p>
        </div>
      ) : (
        <>
          <div class="carousel">
            <div class="carousel-inner" id="carouselInner">
              {photoList.map((photo) => (
                <div class="carousel-item">
                  <img src={photo.src} alt={photo.alt} />
                </div>
              ))}
            </div>

            <button class="carousel-btn prev" id="prevBtn" aria-label="Previous image">‹</button>
            <button class="carousel-btn next" id="nextBtn" aria-label="Next image">›</button>
          </div>

          <div class="carousel-indicators" id="indicators">
            {photoList.map((_, index) => (
              <button
                class={`carousel-indicator ${index === 0 ? 'active' : ''}`}
                data-index={index}
                aria-label={`Go to image ${index + 1}`}
              ></button>
            ))}
          </div>
        </>
      )}

      <div style="text-align: center; margin-top: 3rem;">
        <a href="/" class="btn">Back to Home</a>
      </div>
    </section>
  </div>
</Layout>

<script>
  let currentIndex = 0;
  const carouselInner = document.getElementById('carouselInner');
  const indicators = document.querySelectorAll('.carousel-indicator');
  const totalItems = indicators.length;

  if (carouselInner && totalItems > 0) {
    function updateCarousel() {
      if (carouselInner) {
        carouselInner.style.transform = `translateX(-${currentIndex * 100}%)`;
      }

      indicators.forEach((indicator, index) => {
        if (index === currentIndex) {
          indicator.classList.add('active');
        } else {
          indicator.classList.remove('active');
        }
      });
    }

    function nextSlide() {
      currentIndex = (currentIndex + 1) % totalItems;
      updateCarousel();
    }

    function prevSlide() {
      currentIndex = (currentIndex - 1 + totalItems) % totalItems;
      updateCarousel();
    }

    function goToSlide(index) {
      currentIndex = index;
      updateCarousel();
    }

    // Event listeners
    document.getElementById('nextBtn')?.addEventListener('click', nextSlide);
    document.getElementById('prevBtn')?.addEventListener('click', prevSlide);

    indicators.forEach((indicator, index) => {
      indicator.addEventListener('click', () => goToSlide(index));
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') prevSlide();
      if (e.key === 'ArrowRight') nextSlide();
    });

    // Auto-advance carousel every 5 seconds
    setInterval(nextSlide, 5000);
  }
</script>
