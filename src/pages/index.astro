---
import Layout from '../layouts/Layout.astro';
import experienceData from '../../experience.json';
import projectsData from '../../projects.json';
import { config } from '../config';

const skills = [
  "JavaScript", "TypeScript", "React", "Astro",
  "Node.js", "Python", "FastAPI", "PostgreSQL", "MongoDB",
  "Docker", "AWS", "Tailwind CSS", "GCP", "Azure",
  "Git", "CI/CD", "Machine Learning", "Artificial Intelligence"
];
---

<Layout title="Sachin - Developer & Photographer">
  <div class="container">
    <!-- Hero Section -->
    <section id="hero" style="min-height: 80vh; display: flex; align-items: center; justify-content: center; text-align: center;">
      <div>
        <h1 style="font-size: 3rem; margin-bottom: 1rem;">Hi, I'm Sachin</h1>
        <p style="font-size: 1.25rem; color: #ffc300; max-width: 600px; margin: 0 auto 2rem;">
          I love creating beautiful, functional experiences through code, analyzing data to uncover insights,
          capturing moments through the lens, and exploring life's many passions.
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center;">
          <a href="#projects" class="btn">View My Projects</a>
          <a href="/photography" class="btn">See My Photography</a>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="about">
      <div class="card">
        <h2 style="font-size: 2.5rem; text-align: center;">About Me</h2>
        <p style="margin-bottom: 1rem;">
          Data is the foundation of every function in today's world. I specialize in processing data and transforming it into actionable insights that drive informed decisions.
          Coming with nearly 5 years of work experience, I am currently pursing my Master's in Computer Science at
          <a href="https://asu.edu" target="_blank" rel="noopener noreferrer">Arizona State University</a>.
        </p>
        <p style="margin-bottom: 1rem;">
          This website is what I'm trying to build while also learning web development. In the not so distant future, I'd love to build applications
          that are not just functional and visually appealing, but also tell a story.
        </p>
        <p style="margin-bottom: 2rem;">
          When I'm not coding, you can find me out in the wild, exploring new places and showing other people the world through my lens.
        </p>

        <h3 style="font-size: 1.5rem; margin-bottom: 1rem;">Skills & Technologies</h3>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
          {skills.map((skill) => (
            <span style="background: #003566; padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.9rem;">
              {skill}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section id="experience">
      <h2 style="font-size: 2.5rem; text-align: center; margin-bottom: 2rem;">Experience</h2>
      <div class="card experience-container">
        <div class="experience-tabs">
          {experienceData.map((exp, index) => (
            <button
              class={`experience-tab ${index === 0 ? 'active' : ''}`}
              data-index={index}
            >
              <span class="company-name">{exp.company}</span>
            </button>
          ))}
        </div>

        <div class="experience-content">
          {experienceData.map((exp, index) => (
            <div
              class={`experience-panel ${index === 0 ? 'active' : ''}`}
              data-index={index}
            >
              <h3 style="font-size: 1.75rem; margin-bottom: 0.5rem;">
                <a href={exp.link} target="_blank" rel="noopener noreferrer" style="color: #ffd60a;">
                  {exp.position}
                </a>
              </h3>
              <p style="color: #ffc300; margin-bottom: 1rem;">
                {exp.startDate} - {exp.endDate}
              </p>
              <ul style="margin-bottom: 1.5rem; padding-left: 1.5rem;">
                {exp.highlights.map((highlight) => (
                  <li style="margin-bottom: 0.75rem; line-height: 1.6;">{highlight}</li>
                ))}
              </ul>
              <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                {exp.technologies.map((tech) => (
                  <span style="background: #001d3d; padding: 0.25rem 0.75rem; border-radius: 4px; font-size: 0.85rem;">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section id="projects">
      <h2 style="font-size: 2.5rem; text-align: center; margin-bottom: 2rem;">Featured Projects</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
        {projectsData.map((project) => (
          <div class="card">
            <h3 style="font-size: 1.5rem; margin-bottom: 0.5rem;">{project.title}</h3>
            <p style="margin-bottom: 1rem;">{project.description}</p>
            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem;">
              {project.technologies.map((tech) => (
                <span style="background: #001d3d; padding: 0.25rem 0.75rem; border-radius: 4px; font-size: 0.85rem;">
                  {tech}
                </span>
              ))}
            </div>
            <div style="display: flex; gap: 1rem;">
              <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="btn" style="font-size: 0.9rem; padding: 0.5rem 1rem;">
                GitHub
              </a>
              {project.liveUrl && (
                <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="btn" style="font-size: 0.9rem; padding: 0.5rem 1rem;">
                  Live Demo
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
      <div style="text-align: center; margin-top: 2rem;">
        <a href="https://github.com/SachinVenugopalan30" target="_blank" rel="noopener noreferrer" class="btn">
          View All Projects on GitHub
        </a>
      </div>
    </section>

    <!-- Contact Section -->
    <section id="contact">
      <div class="card" style="text-align: center;">
        <h2 style="font-size: 2.5rem; margin-bottom: 1rem;">Get In Touch</h2>
        <p style="margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">
          I'm currently looking for internships this coming Summer (2026), specifically in the Data Science or Software Engineering domain.
          If you what you find here is interesting, feel free to reach out and we can have a chat!
        </p>
        <a href={`mailto:${config.email}`} class="btn">Say Hello!</a>

        <div style="display: flex; justify-content: center; gap: 1.5rem; margin-top: 2rem; font-size: 1.5rem;">
          {config.socialMedia.github && (
            <a href={config.socialMedia.github} target="_blank" rel="noopener noreferrer" title="GitHub">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
          )}
          {config.socialMedia.linkedin && (
            <a href={config.socialMedia.linkedin} target="_blank" rel="noopener noreferrer" title="LinkedIn">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </a>
          )}
          {config.socialMedia.instagram && (
            <a href={config.socialMedia.instagram} target="_blank" rel="noopener noreferrer" title="Instagram">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          )}
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .experience-container {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
    align-items: start;
  }

  .experience-tabs {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-right: 2px solid #003566;
    padding-right: 1rem;
  }

  .experience-tab {
    background: transparent;
    border: none;
    border-left: 3px solid transparent;
    padding: 0.75rem 1rem;
    text-align: left;
    cursor: pointer;
    color: #ffc300;
    font-size: 1rem;
    transition: all 0.3s ease;
    position: relative;
  }

  .experience-tab:hover {
    background: rgba(0, 53, 102, 0.3);
    border-left-color: #ffc300;
  }

  .experience-tab.active {
    background: rgba(0, 53, 102, 0.5);
    border-left-color: #ffd60a;
    color: #ffd60a;
  }

  .experience-content {
    position: relative;
    min-height: 300px;
  }

  .experience-panel {
    display: none;
    animation: fadeIn 0.3s ease-in;
  }

  .experience-panel.active {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive design for mobile */
  @media (max-width: 768px) {
    .experience-container {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .experience-tabs {
      flex-direction: row;
      overflow-x: auto;
      border-right: none;
      border-bottom: 2px solid #003566;
      padding-right: 0;
      padding-bottom: 0.5rem;
    }

    .experience-tab {
      border-left: none;
      border-bottom: 3px solid transparent;
      white-space: nowrap;
      padding: 0.75rem 1rem;
    }

    .experience-tab:hover,
    .experience-tab.active {
      border-left: none;
      border-bottom-color: #ffd60a;
    }
  }
</style>

<script>
  // Experience tabs functionality
  const tabs = document.querySelectorAll('.experience-tab');
  const panels = document.querySelectorAll('.experience-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const index = tab.getAttribute('data-index');

      // Remove active class from all tabs and panels
      tabs.forEach(t => t.classList.remove('active'));
      panels.forEach(p => p.classList.remove('active'));

      // Add active class to clicked tab and corresponding panel
      tab.classList.add('active');
      const activePanel = document.querySelector(`.experience-panel[data-index="${index}"]`);
      if (activePanel) {
        activePanel.classList.add('active');
      }
    });
  });
</script>
